generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExperienceLevel {
  fresher
  junior
  mid
  senior
}

enum AssessmentStatus {
  draft
  active
  completed
  archived
}

enum AttemptStatus {
  started
  submitted
  evaluated
}

enum InterviewStatus {
  scheduled
  live
  completed
  cancelled
}

enum AnswerModality {
  text
  audio
  video
  multimodal
}

enum TaskStatus {
  todo
  in_progress
  done
  skipped
}

model User {
  id                 String              @id @default(uuid())
  name               String
  email              String              @unique
  passwordHash       String
  experienceLevel    ExperienceLevel     @default(fresher)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  resumes            Resume[]
  targetRoles        TargetRole[]
  assessments        Assessment[]
  interviewSessions  InterviewSession[]
  interviewDnaMemory InterviewDnaMemory?
  learningRoadmaps   LearningRoadmap[]
  calendarEvents     CalendarEvent[]
  notifications      Notification[]
}

model Resume {
  id           String       @id @default(uuid())
  userId       String
  fileUrl      String
  parsedText   String?
  summary      String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills       Skill[]
  assessments  Assessment[]
}

model TargetCompany {
  id          String       @id @default(uuid())
  name        String
  website     String?
  description String?
  createdAt   DateTime     @default(now())
  targetRoles TargetRole[]
}

model TargetRole {
  id              String         @id @default(uuid())
  userId          String
  targetCompanyId String?
  title           String
  jobDescription  String
  seniority       String?
  createdAt       DateTime       @default(now())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetCompany   TargetCompany? @relation(fields: [targetCompanyId], references: [id])
  competencies    Competency[]
  assessments     Assessment[]
}

model Skill {
  id           String       @id @default(uuid())
  resumeId     String
  name         String
  category     String
  confidence   Float        @default(0)
  evidence     String?
  resume       Resume       @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  competencies Competency[]
}

model Competency {
  id               String            @id @default(uuid())
  targetRoleId     String
  skillId          String?
  name             String
  description      String?
  expectedLevel    Int               @default(3)
  targetRole       TargetRole        @relation(fields: [targetRoleId], references: [id], onDelete: Cascade)
  skill            Skill?            @relation(fields: [skillId], references: [id])
  scores           CompetencyScore[]
  questions        Question[]
  roadmapTasks     RoadmapTask[]
}

model CompetencyScore {
  id             String      @id @default(uuid())
  competencyId   String
  assessmentId   String?
  score          Int
  confidence     Float       @default(0)
  evidence       String?
  recommendation String?
  createdAt      DateTime    @default(now())
  competency     Competency  @relation(fields: [competencyId], references: [id], onDelete: Cascade)
  assessment     Assessment? @relation(fields: [assessmentId], references: [id])
}

model Assessment {
  id             String             @id @default(uuid())
  userId         String
  resumeId       String
  targetRoleId   String
  status         AssessmentStatus   @default(draft)
  overallScore   Int?
  gapSummary     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  resume         Resume             @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  targetRole     TargetRole         @relation(fields: [targetRoleId], references: [id], onDelete: Cascade)
  competencyScores CompetencyScore[]
  questions      Question[]
  attempts       QuestionAttempt[]
  roadmap        LearningRoadmap?
}

model Question {
  id             String             @id @default(uuid())
  assessmentId   String
  competencyId   String?
  prompt         String
  difficulty     String
  expectedAnswer String?
  createdAt      DateTime           @default(now())
  assessment     Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  competency     Competency?        @relation(fields: [competencyId], references: [id])
  attempts       QuestionAttempt[]
  hints          Hint[]
}

model QuestionAttempt {
  id                 String            @id @default(uuid())
  assessmentId        String
  questionId          String
  interviewSessionId  String?
  answerText          String?
  audioUrl            String?
  videoUrl            String?
  modality            AnswerModality   @default(text)
  score               Int?
  feedback            String?
  status              AttemptStatus    @default(started)
  createdAt           DateTime         @default(now())
  assessment          Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question            Question         @relation(fields: [questionId], references: [id], onDelete: Cascade)
  interviewSession    InterviewSession? @relation(fields: [interviewSessionId], references: [id])
}

model Hint {
  id         String    @id @default(uuid())
  questionId String?
  content    String
  context    String?
  createdAt  DateTime  @default(now())
  question   Question? @relation(fields: [questionId], references: [id])
}

model InterviewSession {
  id          String              @id @default(uuid())
  userId      String
  roadmapId   String?
  scheduledAt DateTime?
  transcript  String?
  status      InterviewStatus     @default(scheduled)
  createdAt   DateTime            @default(now())
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  roadmap     LearningRoadmap?    @relation(fields: [roadmapId], references: [id])
  attempts    QuestionAttempt[]
  feedback    InterviewFeedback?
}

model InterviewFeedback {
  id                 String           @id @default(uuid())
  interviewSessionId String           @unique
  overallScore        Int
  technicalScore      Int?
  communicationScore  Int?
  confidenceScore     Int?
  behavioralSummary   String?
  oceanSnapshot       Json?
  strengths           Json
  gaps                Json
  nextPracticePlan    Json
  createdAt           DateTime         @default(now())
  interviewSession    InterviewSession @relation(fields: [interviewSessionId], references: [id], onDelete: Cascade)
}

model InterviewDnaMemory {
  id                  String   @id @default(uuid())
  userId              String   @unique
  memorySummary       String
  strengths           Json
  recurringGaps       Json
  lastDifficultyLevel Int      @default(1)
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LearningRoadmap {
  id            String             @id @default(uuid())
  userId        String
  assessmentId  String             @unique
  title         String
  summary       String?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  assessment    Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  tasks         RoadmapTask[]
  sessions      InterviewSession[]
}

model RoadmapTask {
  id             String          @id @default(uuid())
  roadmapId       String
  competencyId    String?
  title           String
  description     String?
  resourceUrl     String?
  dueDate         DateTime?
  status          TaskStatus       @default(todo)
  roadmap         LearningRoadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
  competency      Competency?      @relation(fields: [competencyId], references: [id])
}

model CalendarEvent {
  id          String   @id @default(uuid())
  userId      String
  title       String
  startsAt    DateTime
  endsAt      DateTime
  providerRef String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(uuid())
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}
